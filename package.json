{
  "name": "@trailofbits/vsix-audit",
  "version": "0.3.0",
  "description": "Security scanner for VS Code extensions",
  "keywords": [
    "audit",
    "scanner",
    "security",
    "trail-of-bits",
    "vscode",
    "vsix"
  ],
  "homepage": "https://github.com/trailofbits/vsix-audit#readme",
  "bugs": {
    "url": "https://github.com/trailofbits/vsix-audit/issues"
  },
  "license": "AGPL-3.0",
  "author": "Trail of Bits",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trailofbits/vsix-audit.git"
  },
  "bin": {
    "vsix-audit": "dist/index.js"
  },
  "files": [
    "dist",
    "zoo"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:cli": "npm run build && vitest run --config vitest.cli.config.ts",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "corpus:download": "npm run build && node scripts/download-clean-corpus.mjs",
    "corpus:report": "npm run build && node scripts/report-clean-corpus.mjs",
    "corpus:check": "npm run build && node scripts/report-clean-corpus.mjs --fail-on-never",
    "check": "npm run typecheck && npm run lint && npm run test && npm run test:cli",
    "prepublishOnly": "npm run check && npm run build"
  },
  "dependencies": {
    "@types/yauzl": "2.10.3",
    "commander": "14.0.3",
    "oxc-parser": "0.132.0",
    "picocolors": "1.1.1",
    "yauzl": "3.3.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "oxlint": "1.56.0",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=22"
  }
}
